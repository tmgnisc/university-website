# Neon Postgres connection string (Neon dashboard → Connection string, pooled).
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Secret used to sign admin JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# Initial admin account created by `npm run seed`.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Allowed browser origins for CORS (comma-separated). Set this to your site's
# URL(s) in production. Defaults to * if unset.
CORS_ORIGIN=http://localhost:8080,https://your-site.example.edu
