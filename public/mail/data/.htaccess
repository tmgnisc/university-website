# Belt-and-suspenders: block direct access to the submissions store even
# though submissions.php itself already exits immediately when requested
# directly (see SUBMISSIONS_GUARD in ../lib.php).

# Apache 2.4+
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Apache 2.2
<IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
</IfModule>
