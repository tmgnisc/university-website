# Copy to `.env` and fill in. Only variables prefixed with VITE_ are exposed
# to the browser (via import.meta.env.VITE_*). Never put secrets here.
#
# Server-only secrets belong in process.env and are read inside handlers —
# see src/lib/config.server.ts.

# Example public value:
# VITE_PUBLIC_SITE_URL=https://example.edu

# --- Admin CMS ---
# Mock admin login credentials (interim, until the Node/SQL backend exists).
# Defaults to admin / admin123 if unset.
# VITE_ADMIN_USERNAME=admin
# VITE_ADMIN_PASSWORD=admin123
#
# When the backend is ready, point the admin at it and CRUD goes live:
# VITE_CMS_API_URL=https://api.example.edu
